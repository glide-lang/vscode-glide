{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Glide",
  "scopeName": "source.glide",
  "fileTypes": ["glide"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#chars" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#operators" },
    { "include": "#fn-decl" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.glide",
          "match": "//.*$"
        },
        {
          "name": "comment.block.glide",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.glide",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "name": "constant.character.escape.glide", "match": "\\\\." }
      ]
    },
    "chars": {
      "name": "string.quoted.single.glide",
      "begin": "'",
      "end": "'",
      "patterns": [
        { "name": "constant.character.escape.glide", "match": "\\\\." }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.float.glide", "match": "\\b\\d[\\d_]*\\.\\d[\\d_]*\\b" },
        { "name": "constant.numeric.integer.glide", "match": "\\b\\d[\\d_]*\\b" }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.glide",
          "match": "\\b(if|else|while|for|return|break|continue|match|defer|spawn|import)\\b"
        },
        {
          "name": "keyword.declaration.glide",
          "match": "\\b(let|const|fn|struct|enum|impl|interface|type|extern|pub|mut|move)\\b"
        },
        {
          "name": "keyword.operator.glide",
          "match": "\\b(as)\\b"
        },
        {
          "name": "constant.language.glide",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.glide",
          "match": "\\b(int|uint|long|ulong|i8|i16|i32|i64|u8|u16|u32|u64|usize|isize|f32|f64|float|bool|string|char|void|chan)\\b"
        },
        {
          "name": "entity.name.type.glide",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "operators": {
      "name": "keyword.operator.glide",
      "match": "(==|!=|<=|>=|&&|\\|\\||<<|>>|->|=>|::|\\+=|-=|\\*=|/=|\\+\\+|--|[+\\-*/%<>=!&|^~?])"
    },
    "fn-decl": {
      "match": "\\b(fn)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.glide" },
        "2": { "name": "entity.name.function.glide" }
      }
    },
    "identifiers": {
      "name": "variable.other.glide",
      "match": "\\b[a-z_][A-Za-z0-9_]*\\b"
    }
  }
}
