{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Glide",
  "scopeName": "source.glide",
  "fileTypes": ["glide"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#chars" },
    { "include": "#numbers" },
    { "include": "#attributes" },
    { "include": "#keywords" },
    { "include": "#macro-call" },
    { "include": "#types" },
    { "include": "#fn-decl" },
    { "include": "#function-call" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.glide",
          "match": "//.*$"
        },
        {
          "name": "comment.block.glide",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.glide",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "name": "constant.character.escape.glide", "match": "\\\\." }
      ]
    },
    "chars": {
      "name": "string.quoted.single.glide",
      "begin": "'",
      "end": "'",
      "patterns": [
        { "name": "constant.character.escape.glide", "match": "\\\\." }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.float.glide", "match": "\\b\\d[\\d_]*\\.\\d[\\d_]*\\b" },
        { "name": "constant.numeric.integer.glide", "match": "\\b\\d[\\d_]*\\b" }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.glide",
          "match": "\\b(if|else|while|for|in|return|break|continue|match|defer|defer_err|spawn|spawn_thread|import)\\b"
        },
        {
          "name": "keyword.declaration.glide",
          "match": "\\b(let|const|fn|struct|enum|impl|interface|trait|type|extern|pub|mut|move|dyn|macro|naked)\\b"
        },
        {
          "name": "keyword.other.glide",
          "match": "\\b(c_raw|c_include|c_link|asm|volatile)\\b"
        },
        {
          "name": "keyword.operator.glide",
          "match": "\\b(as|sizeof)\\b"
        },
        {
          "name": "constant.language.glide",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.glide",
          "match": "\\b(int|uint|long|ulong|i8|i16|i32|i64|i128|i256|u8|u16|u32|u64|u128|u256|usize|isize|f32|f64|float|bool|string|char|void|chan)\\b"
        },
        {
          "name": "entity.name.type.glide",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "operators": {
      "name": "keyword.operator.glide",
      "match": "(==|!=|<=|>=|&&|\\|\\||<<|>>|->|=>|::|\\+=|-=|\\*=|/=|\\+\\+|--|[+\\-*/%<>=!&|^~?])"
    },
    "fn-decl": {
      "match": "\\b(fn)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.glide" },
        "2": { "name": "entity.name.function.glide" }
      }
    },
    "attributes": {
      "comment": "@cfg, @derive(...), @get/@post route attrs, @handler, etc.",
      "name": "storage.modifier.attribute.glide",
      "match": "@[A-Za-z_][A-Za-z0-9_]*"
    },
    "macro-call": {
      "comment": "name!(...) macro invocations like println!, vec_of!, assert!",
      "name": "entity.name.function.macro.glide",
      "match": "\\b[A-Za-z_][A-Za-z0-9_]*!"
    },
    "function-call": {
      "comment": "lowercase identifier directly before `(` — a call target. Covers method/constructor names like `new(`, `send(` that aren't type-cased.",
      "match": "\\b([a-z_][A-Za-z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.glide" }
      }
    },
    "identifiers": {
      "name": "variable.other.glide",
      "match": "\\b[a-z_][A-Za-z0-9_]*\\b"
    }
  }
}
